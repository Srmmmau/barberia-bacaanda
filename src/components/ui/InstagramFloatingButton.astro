---
import { instagramUrl } from '@/lib/contact';

interface Props {
  label: string;
}

const { label } = Astro.props;
---

<a
  href={instagramUrl()}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
  class="fixed bottom-[88px] right-5 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-primary text-text shadow-xl transition hover:scale-105"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-7 w-7">
    <rect x="3" y="3" width="18" height="18" rx="5" />
    <circle cx="12" cy="12" r="4" />
    <circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none" />
  </svg>
</a>

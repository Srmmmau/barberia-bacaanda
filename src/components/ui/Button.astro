---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'call' | 'outline';
  class?: string;
  external?: boolean;
}

const { href, variant = 'primary', class: className = '', external = true } = Astro.props;

const variants = {
  primary: 'bg-gold text-ink hover:bg-gold-hover shadow-glow',
  secondary: 'bg-[#25D366] text-ink hover:brightness-95',
  call: 'bg-primary text-text hover:bg-primary-hover',
  outline: 'border border-border text-text hover:border-gold hover:text-gold',
};
---

<a
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class:list={[
    'inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 font-display text-sm font-semibold uppercase tracking-wide transition',
    variants[variant],
    className,
  ]}
>
  <slot />
</a>

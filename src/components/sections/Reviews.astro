---
import type { SiteCopy } from '@/content/types';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
---

<section id="resenas" class="border-t border-border/60 bg-surface/40 py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <h2 class="font-display text-3xl sm:text-4xl">{copy.reviews.heading}</h2>
      <div class="flex items-center gap-3">
        <span class="font-display text-3xl text-gold">{copy.reviews.ratingValue}</span>
        <div>
          <div class="text-gold">★★★★★</div>
          <div class="text-xs text-muted">{copy.reviews.ratingCount}</div>
        </div>
      </div>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {copy.reviews.quotes.map((quote) => (
        <blockquote class="flex h-full flex-col justify-between rounded-2xl border border-border bg-surface p-6">
          <p class="text-sm leading-relaxed text-text/90">"{quote.text}"</p>
          <footer class="mt-6 text-xs text-muted">
            <span class="font-semibold text-text">{quote.author}</span> · {quote.meta}
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

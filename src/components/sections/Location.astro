---
import Button from '@/components/ui/Button.astro';
import { telUrl, whatsappUrl, instagramUrl, wazeUrl, googleMapsUrl, formattedPhone } from '@/lib/contact';
import type { SiteCopy } from '@/content/types';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(copy.location.mapQuery)}&output=embed`;
---

<section id="ubicacion" class="py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 class="font-display text-3xl sm:text-4xl">{copy.location.heading}</h2>

    <div class="mt-10 grid gap-8 lg:grid-cols-2 lg:items-stretch">
      <div class="overflow-hidden rounded-2xl border border-border">
        <iframe
          src={mapSrc}
          class="h-72 w-full lg:h-full"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Barbería Bacaanda en el mapa"
        ></iframe>
      </div>

      <div class="flex flex-col justify-center gap-6 rounded-2xl border border-border bg-surface p-8">
        <address class="not-italic">
          {copy.location.addressLines.map((line) => (
            <span class="block text-base text-text/90">{line}</span>
          ))}
        </address>

        <div>
          <h3 class="font-display text-sm uppercase tracking-wide text-muted">{copy.location.hoursHeading}</h3>
          <dl class="mt-2 space-y-1">
            {copy.location.hours.map((row) => (
              <div class="flex justify-between gap-4 text-sm">
                <dt class="text-text/90">{row.label}</dt>
                <dd class="text-muted">{row.time}</dd>
              </div>
            ))}
          </dl>
        </div>

        <p class="text-sm text-muted">{copy.location.hoursNote}</p>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <Button href={telUrl()} variant="call" external={false}>
            {copy.location.phoneLabel} · {formattedPhone()}
          </Button>
          <Button href={whatsappUrl(copy.finalCta.whatsappMessage)} variant="secondary">
            {copy.location.whatsappLabel}
          </Button>
          <Button href={instagramUrl()} variant="instagram">
            {copy.location.instagramLabel}
          </Button>
        </div>

        <div class="flex flex-wrap gap-3">
          <a
            href={wazeUrl()}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-2 text-xs font-semibold uppercase tracking-wide text-muted transition hover:border-gold hover:text-gold"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
              <path d="M9 20l3-16 3 16M6 15h12" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {copy.location.wazeLabel}
          </a>
          <a
            href={googleMapsUrl()}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-2 text-xs font-semibold uppercase tracking-wide text-muted transition hover:border-gold hover:text-gold"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
              <path
                d="M12 21s7-6.1 7-11.5A7 7 0 0 0 5 9.5C5 14.9 12 21 12 21Z"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <circle cx="12" cy="9.5" r="2.3" />
            </svg>
            {copy.location.mapsLabel}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

---
import logo from '@/assets/brand/logo.png';
import { agendaProIframeSrc, bookingUrl } from '@/lib/contact';
import type { SiteCopy } from '@/content/types';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
---

<section id="agendar" class="border-t border-border/60 py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <div class="text-center">
      <h2 class="font-display text-3xl sm:text-4xl">{copy.booking.heading}</h2>
      <p class="mt-3 text-base text-muted sm:text-lg">{copy.booking.subheading}</p>
    </div>

    <div class="brand-glow-ring mt-10 rounded-[28px] p-[3px]">
      <div class="overflow-hidden rounded-[25px] bg-surface">
        <div class="flex items-center gap-3 bg-surface px-5 py-4">
          <img src={logo.src} alt="Barbería Bacaanda" class="h-9 w-9 rounded-full" />
          <div>
            <p class="font-display text-sm uppercase tracking-wide text-text">{copy.booking.heading}</p>
            <p class="text-xs text-muted">Powered by AgendaPro</p>
          </div>
        </div>
        <iframe
          src={agendaProIframeSrc()}
          title={copy.booking.heading}
          width="100%"
          height="720"
          style="border:0; display:block; margin:0;"
        ></iframe>
      </div>
    </div>

    <p class="mt-4 text-center text-sm text-muted">
      <a href={bookingUrl()} target="_blank" rel="noopener noreferrer" class="underline hover:text-gold">
        {copy.booking.fallbackLabel}
      </a>
    </p>
  </div>
</section>

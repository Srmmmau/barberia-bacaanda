---
import Button from '@/components/ui/Button.astro';
import { bookingUrl, whatsappUrl } from '@/lib/contact';
import type { SiteCopy } from '@/content/types';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
---

<section class="border-t border-border/60 bg-surface/40 py-20">
  <div class="mx-auto flex max-w-4xl flex-col items-center gap-6 px-4 text-center sm:px-6">
    <h2 class="font-display text-3xl sm:text-4xl">{copy.finalCta.heading}</h2>
    <p class="max-w-xl text-base text-muted sm:text-lg">{copy.finalCta.subheading}</p>
    <div class="mt-2 flex flex-wrap justify-center gap-3">
      <Button href={bookingUrl()} variant="primary">{copy.hero.ctaBook}</Button>
      <Button href={whatsappUrl(copy.finalCta.whatsappMessage)} variant="secondary">
        {copy.hero.ctaWhatsapp}
      </Button>
    </div>
  </div>
</section>

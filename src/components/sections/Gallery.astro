---
import { Image } from 'astro:assets';
import photo1 from '@/assets/gallery/photo-1.png';
import photo2 from '@/assets/gallery/photo-2.png';
import photo3 from '@/assets/gallery/photo-3.png';
import photo4 from '@/assets/gallery/photo-4.png';
import photo5 from '@/assets/gallery/photo-5.png';
import photo6 from '@/assets/gallery/photo-6.png';
import type { SiteCopy } from '@/content/types';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;

const photos = [
  { src: photo2, alt: 'Barbero de Bacaanda haciendo un fade frente al mural del estudio', span: 'lg:row-span-2' },
  { src: photo1, alt: 'Hot shave con toalla caliente en Bacaanda' },
  { src: photo3, alt: 'Logotipo de Barbería Bacaanda sobre un corte en proceso' },
  { src: photo6, alt: 'Barbero terminando un corte frente al mural de la catrina', span: 'lg:row-span-2' },
  { src: photo4, alt: 'Retrato en el estudio Bacaanda' },
  { src: photo5, alt: 'Retrato de uno de los barberos de Bacaanda' },
];
---

<section id="galeria" class="py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="max-w-2xl">
      <h2 class="font-display text-3xl sm:text-4xl">{copy.gallery.heading}</h2>
      <p class="mt-3 text-base text-muted sm:text-lg">{copy.gallery.subheading}</p>
    </div>

    <div class="mt-10 grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4 lg:grid-rows-2">
      {photos.map((photo) => (
        <div class:list={['overflow-hidden rounded-2xl', photo.span]}>
          <Image
            src={photo.src}
            alt={photo.alt}
            class="h-full w-full object-cover transition duration-300 hover:scale-105"
            widths={[320, 640, 960]}
            sizes="(min-width: 1024px) 25vw, 50vw"
          />
        </div>
      ))}
    </div>
  </div>
</section>

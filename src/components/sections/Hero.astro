---
import { Image } from 'astro:assets';
import heroPhoto from '@/assets/gallery/mural-hero.jpg';
import Button from '@/components/ui/Button.astro';
import { whatsappUrl, telUrl } from '@/lib/contact';
import type { SiteCopy } from '@/content/types';

interface Props {
  copy: SiteCopy;
}

const { copy } = Astro.props;
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0">
    <Image
      src={heroPhoto}
      alt="Mural de la catrina con tocado de girasol y serpiente en el estudio de Bacaanda"
      class="h-full w-full object-cover object-[62%_48%]"
      widths={[640, 1024, 1600]}
      sizes="100vw"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/85 to-ink/40"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-ink/90 via-ink/30 to-transparent"></div>
  </div>

  <div class="relative mx-auto flex max-w-6xl flex-col gap-6 px-4 py-28 sm:px-6 sm:py-36 lg:py-44">
    <span class="brand-glow-ring w-fit rounded-full p-[1.5px]">
      <span class="block rounded-full bg-ink px-4 py-1 text-xs font-semibold uppercase tracking-widest text-gold">
        {copy.hero.eyebrow}
      </span>
    </span>

    <h1 class="max-w-2xl font-display text-4xl leading-[1.05] sm:text-6xl">
      {copy.hero.title}
    </h1>

    <p class="max-w-xl text-base text-muted sm:text-lg">
      {copy.hero.subtitle}
    </p>

    <div class="flex items-center gap-2 text-sm">
      <span class="text-gold">★★★★★</span>
      <span class="font-semibold">4.8</span>
      <span class="text-muted">{copy.hero.ratingLabel}</span>
    </div>

    <div class="mt-4 flex flex-wrap gap-3">
      <Button href="#agendar" variant="primary" external={false}>{copy.hero.ctaBook}</Button>
      <Button href={whatsappUrl(copy.hero.whatsappMessage)} variant="secondary">
        {copy.hero.ctaWhatsapp}
      </Button>
      <Button href={telUrl()} variant="call" external={false}>{copy.location.phoneLabel}</Button>
    </div>
  </div>
</section>

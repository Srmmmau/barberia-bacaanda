---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout
  lang="es"
  title="Página no encontrada — Barbería Bacaanda"
  description="La página que buscas no existe."
>
  <main class="flex min-h-screen flex-col items-center justify-center gap-4 px-4 text-center">
    <h1 class="font-display text-4xl">404</h1>
    <p class="text-muted">No encontramos esta página.</p>
    <Button href="/es/" external={false} variant="primary">Volver al inicio</Button>
  </main>
</BaseLayout>

---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import FloatingActions from '@/components/ui/FloatingActions.astro';
import Hero from '@/components/sections/Hero.astro';
import About from '@/components/sections/About.astro';
import Services from '@/components/sections/Services.astro';
import Booking from '@/components/sections/Booking.astro';
import Gallery from '@/components/sections/Gallery.astro';
import Reviews from '@/components/sections/Reviews.astro';
import Location from '@/components/sections/Location.astro';
import CTASection from '@/components/sections/CTASection.astro';
import { copy } from '@/content';

const c = copy.en;
---

<BaseLayout lang="en" title={c.meta.title} description={c.meta.description}>
  <Header lang="en" copy={c} />
  <main>
    <Hero copy={c} />
    <About copy={c} />
    <Services copy={c} />
    <Booking copy={c} />
    <Gallery copy={c} />
    <Reviews copy={c} />
    <Location copy={c} />
    <CTASection copy={c} />
  </main>
  <Footer copy={c} />
  <FloatingActions copy={c} />
</BaseLayout>
